# Symphony 配置示例 —— 复制为 data/config.toml 后填入你自己的 API Key
#   cp data/config.toml.example data/config.toml
# 说明：data/config.toml 已被 .gitignore 忽略（含密钥，切勿提交）。

active_provider = "doubao"

# 默认 provider（可被 [providers.*] 覆盖）
[provider]
type = "openai"
base_url = "https://ark-cn-beijing.bytedance.net/api/v3"
api_key = "YOUR_API_KEY_HERE"
model = "YOUR_ENDPOINT_ID"
max_tokens = 32768
temperature = 0.7

# 火山引擎豆包（OpenAI 兼容）
[providers.doubao]
type = "openai"
base_url = "https://ark-cn-beijing.bytedance.net/api/v3"
api_key = "YOUR_DOUBAO_API_KEY"
model = "YOUR_DOUBAO_ENDPOINT_ID"
max_tokens = 32768
temperature = 0.2

# Mira（ByteDance 内部，鉴权用 mira_session JWT）
[providers.mira]
type = "mira"
base_url = "https://mira.byteintl.net"
api_key = "YOUR_MIRA_SESSION_JWT"
model = "re-o-48"
max_tokens = 32768
temperature = 0.7

[pi_agent]
binary_path = "pi"
default_model = ""
startup_timeout = 30.0
request_timeout = 120.0
thinking_level = "medium"
auto_compaction = true

[web_ui]
host = "0.0.0.0"
port = 8765
theme = "dark"
auto_scroll = true
max_log_entries = 1000
refresh_interval_ms = 100

[tui]
theme = "textual-dark"
compact_view = false
log_normal_chat = true
